{
  "name": "reversealignment.tw",
  "version": "1.0.0",
  "private": true,
  "license": "CC0-1.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "prepare": "vp config",
    "test:unit": "vp test tests/unit",
    "test:e2e": "vp exec playwright test",
    "test:e2e:install": "vp exec playwright install --with-deps",
    "lint:html": "html-validate \"dist/index.html\" \"dist/404.html\"",
    "ci": "vp run clean && vp check && vp build && vp test && vp run lint:html"
  },
  "dependencies": {
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "html-validate": "^10.13.1",
    "serve": "^14.2.6",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "packageManager": "bun@1.3.14"
}
