---
import HomePage from '../../components/HomePage.astro';
import Base from '../../layouts/Base.astro';
import { isLocale, listAlternateLocales } from '../../lib/i18n';
import type { Locale } from '../../lib/types';

export function getStaticPaths() {
  return listAlternateLocales().map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

type Props = { locale: Locale };
const param = Astro.params.locale;
if (!param || !isLocale(param)) {
  throw new Error(`Unknown locale route: ${param}`);
}
const locale = (Astro.props.locale ?? param) as Locale;
---

<Base locale={locale}>
  <HomePage locale={locale} />
</Base>
