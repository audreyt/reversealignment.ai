---
import type { FormSpec } from '../lib/types';
import { formFieldDomId } from '../lib/i18n';
type Props = {
  form: FormSpec;
  variant?: 'default' | 'on-dark';
};

const { form, variant = 'default' } = Astro.props;
const formClass = variant === 'on-dark' ? 'form form--on-dark' : 'form';
const action = form.action;
if (!action) {
  throw new Error(`Form "${form.id}" is missing a real action URL`);
}
const isMailto = /^mailto:/i.test(action);
// Mailto bodies are more reliable via POST + text/plain than GET query strings.
const method = isMailto
  ? 'post'
  : (form.method || 'post').toLowerCase() === 'get'
    ? 'get'
    : 'post';
const enctype = isMailto ? 'text/plain' : form.enctype;
const note = form.mailClientNote || form.successMessage;
---

<form
  class={formClass}
  id={form.id}
  method={method}
  action={action}
  enctype={enctype}
  accept-charset="UTF-8"
>
  {
    form.fields.map((field) => {
      const id = formFieldDomId(form.id, field);
      return (
        <div class="form__field">
          <label for={id}>{field.label}</label>
          {field.type === 'select' ? (
            <select
              class="form__control"
              id={id}
              name={field.name}
              required={field.required}
              autocomplete={field.autocomplete}
            >
              <option value="" disabled selected>
                {field.label}
              </option>
              {(field.options || []).map((option) => (
                <option value={option}>{option}</option>
              ))}
            </select>
          ) : field.type === 'textarea' ? (
            <textarea
              class="form__control"
              id={id}
              name={field.name}
              required={field.required}
              autocomplete={field.autocomplete}
              placeholder={field.label}
              rows={3}
            />
          ) : (
            <input
              class="form__control"
              id={id}
              name={field.name}
              type={field.type}
              required={field.required}
              autocomplete={field.autocomplete}
              placeholder={field.label}
            />
          )}
        </div>
      );
    })
  }
  {
    note ? (
      <p class="form__note" data-form-note>
        {note}
      </p>
    ) : null
  }
  <button class="btn btn--dark btn--block" type="submit">{form.submitLabel}</button>
</form>
