---
import {
  getContent,
  getDefaultLocale,
  getSite,
  hreflangAlternates,
  listLocales,
  relativeRootPath,
  toBcp47,
  toOgLocale,
} from '../lib/i18n';
import type { Locale } from '../lib/types';

type Props = {
  title?: string;
  description?: string;
  locale?: Locale;
};

const locale = Astro.props.locale ?? getDefaultLocale();
const site = getSite();
const copy = getContent(locale);
const title = Astro.props.title ?? copy.meta.title;
const description = Astro.props.description ?? copy.meta.description;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImage = new URL(copy.meta.ogImage, site.url).toString();
const bcp47 = toBcp47(locale);
const ogLocale = toOgLocale(locale);
const rootPath = relativeRootPath(locale);
const alternates = hreflangAlternates();
const alternateOgLocales = listLocales()
  .filter((candidate) => candidate !== locale)
  .map(toOgLocale);
---

<!doctype html>
<html lang={bcp47}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }
    <link rel="icon" type="image/png" sizes="512x512" href={`${rootPath}favicon.png`} />
    <link rel="icon" type="image/svg+xml" sizes="any" href={`${rootPath}favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    {
      alternateOgLocales.map((alternate) => (
        <meta property="og:locale:alternate" content={alternate} />
      ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="stylesheet" href={`${rootPath}assets/css/main.css`} />
  </head>
  <body>
    <a class="skip-link" href="#main">{copy.a11y.skipToContent}</a>
    <slot />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: site.name,
        url: site.url,
        description,
        inLanguage: bcp47,
      })}
    />
  </body>
</html>
