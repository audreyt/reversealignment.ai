---
import Base from '../layouts/Base.astro';
import { getContent, getDefaultLocale } from '../lib/i18n';

const locale = getDefaultLocale();
const copy = getContent(locale);
const nf = copy.notFound;
---

<Base locale={locale} title={`${nf.title} — ${copy.brand.name}`}>
  <main id="main" class="section section--dark">
    <div class="section__inner stack-md">
      <p class="eyebrow eyebrow--muted">{nf.code}</p>
      <h1 class="display display--lg">{nf.heading}</h1>
      <p class="body">{nf.body}</p>
      <p><a class="btn btn--lime" href="/">{nf.backLabel}</a></p>
    </div>
  </main>
</Base>
